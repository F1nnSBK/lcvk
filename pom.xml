<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>org.pithos</groupId>
    <artifactId>pithos_core</artifactId>
    <version>1.0-SNAPSHOT</version>
    <packaging>jar</packaging>

    <name>Pithos Vector Search Engine</name>

    <properties>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <maven.compiler.source>25</maven.compiler.source>
        <maven.compiler.target>25</maven.compiler.target>
        <graalvm.version>24.1.2</graalvm.version>
        <native.maven.plugin.version>0.10.2</native.maven.plugin.version>
        <junit.version>5.11.0</junit.version>
    </properties>

    <dependencies>
        <!-- LMAX Disruptor for lock-free parallel execution -->
        <dependency>
            <groupId>com.lmax</groupId>
            <artifactId>disruptor</artifactId>
            <version>3.4.4</version>
        </dependency>

        <!-- GraalVM SDK for CEntryPoint and C API annotations -->
        <dependency>
            <groupId>org.graalvm.sdk</groupId>
            <artifactId>graal-sdk</artifactId>
            <version>${graalvm.version}</version>
            <scope>provided</scope>
        </dependency>

        <!-- JUnit 5 for Unit Testing -->
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter-api</artifactId>
            <version>${junit.version}</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter-engine</artifactId>
            <version>${junit.version}</version>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <!-- Maven Compiler Plugin configured for Java 25 and Vector API -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.13.0</version>
                <configuration>
                    <release>25</release>
                    <compilerArgs>
                        <arg>--add-modules</arg>
                        <arg>jdk.incubator.vector</arg>
                    </compilerArgs>
                </configuration>
            </plugin>

            <!-- Maven Surefire Plugin to run unit tests with Vector API -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>3.5.0</version>
                <configuration>
                    <argLine>--add-modules jdk.incubator.vector --enable-native-access=ALL-UNNAMED --sun-misc-unsafe-memory-access=allow</argLine>
                </configuration>
            </plugin>

            <!-- GraalVM Native Image Maven Plugin -->
            <plugin>
                <groupId>org.graalvm.buildtools</groupId>
                <artifactId>native-maven-plugin</artifactId>
                <version>${native.maven.plugin.version}</version>
                <extensions>true</extensions>
                <executions>
                    <execution>
                        <id>build-native</id>
                        <goals>
                            <goal>compile-no-fork</goal>
                        </goals>
                        <phase>package</phase>
                    </execution>
                </executions>
                <configuration>
                    <sharedLibrary>true</sharedLibrary>
                    <imageName>pithos</imageName>
                    <buildArgs>
                        <buildArg>--no-fallback</buildArg>
                        <buildArg>--add-modules=jdk.incubator.vector</buildArg>
                        <buildArg>-H:+UnlockExperimentalVMOptions</buildArg>
                        <buildArg>-H:+VectorAPISupport</buildArg>
                        <buildArg>--parallelism=3</buildArg>
                        <buildArg>-J-Xmx5g</buildArg>
                        <buildArg>-O3</buildArg>
                        <buildArg>-march=native</buildArg>
                    </buildArgs>
                </configuration>
            </plugin>
        </plugins>
    </build>

    <profiles>
        <profile>
            <id>cuda</id>
            <activation>
                <property>
                    <name>cuda.enabled</name>
                    <value>true</value>
                </property>
            </activation>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.codehaus.mojo</groupId>
                        <artifactId>exec-maven-plugin</artifactId>
                        <version>3.3.0</version>
                        <executions>
                            <execution>
                                <id>compile-cuda-and-c-sources</id>
                                <phase>compile</phase>
                                <goals>
                                    <goal>exec</goal>
                                </goals>
                                <configuration>
                                    <executable>sh</executable>
                                    <arguments>
                                        <argument>-c</argument>
                                        <argument>
                                            mkdir -p "${project.build.directory}" &amp;&amp;
                                            nvcc -c "${project.basedir}/src/main/cuda/pithos_kernels.cu" -o "${project.build.directory}/pithos_kernels.o" -O3 -arch=sm_80 -arch=sm_86 -arch=sm_89 -arch=sm_90 -Xptxas=-v -I"${project.basedir}/src/main/cuda" -I"${project.basedir}/src/main/c" &amp;&amp;
                                            nvcc -c "${project.basedir}/src/main/cuda/pithos_cuda_memory.cu" -o "${project.build.directory}/pithos_cuda_memory.o" -O3 -arch=sm_80 -arch=sm_86 -arch=sm_89 -arch=sm_90 -Xptxas=-v -I"${project.basedir}/src/main/cuda" -I"${project.basedir}/src/main/c" &amp;&amp;
                                            gcc -c "${project.basedir}/src/main/c/pithos_cuda.c" -o "${project.build.directory}/pithos_cuda.o" -I"${project.basedir}/src/main/c" -I"${project.basedir}/src/main/cuda" -I/usr/local/cuda/include -I"${env.JAVA_HOME}/include" -I"${env.JAVA_HOME}/include/linux" -fPIC -O3 &amp;&amp;
                                            gcc -c "${project.basedir}/src/main/c/pithos_cuda_devicemanager.c" -o "${project.build.directory}/pithos_cuda_devicemanager.o" -I"${project.basedir}/src/main/c" -I"${project.basedir}/src/main/cuda" -I/usr/local/cuda/include -I"${env.JAVA_HOME}/include" -I"${env.JAVA_HOME}/include/linux" -fPIC -O3 &amp;&amp;
                                            gcc -c "${project.basedir}/src/main/c/pithos_cuda_memorymanager.c" -o "${project.build.directory}/pithos_cuda_memorymanager.o" -I"${project.basedir}/src/main/c" -I"${project.basedir}/src/main/cuda" -I/usr/local/cuda/include -I"${env.JAVA_HOME}/include" -I"${env.JAVA_HOME}/include/linux" -fPIC -O3 &amp;&amp;
                                            gcc -c "${project.basedir}/src/main/c/pithos_cuda_nativebindings.c" -o "${project.build.directory}/pithos_cuda_nativebindings.o" -I"${project.basedir}/src/main/c" -I"${project.basedir}/src/main/cuda" -I/usr/local/cuda/include -I"${env.JAVA_HOME}/include" -I"${env.JAVA_HOME}/include/linux" -fPIC -O3 &amp;&amp;
                                            gcc -c "${project.basedir}/src/main/c/pithos_capi_cuda.c" -o "${project.build.directory}/pithos_capi_cuda.o" -I"${project.basedir}/src/main/c" -I"${project.basedir}/src/main/cuda" -I/usr/local/cuda/include -I"${env.JAVA_HOME}/include" -I"${env.JAVA_HOME}/include/linux" -fPIC -O3 &amp;&amp;
                                            cat &lt;&lt; 'EOF' &gt; "${project.build.directory}/gcc-wrapper.sh"
#!/bin/bash
echo "gcc-wrapper: calling with args: $@" &gt;&gt; "${project.build.directory}/gcc_wrapper.log"
version_script_file=""
for arg in "$@"; do
    if [[ "$arg" == *"--version-script"* ]]; then
        if [[ "$arg" == *","* ]]; then
            version_script_file="${arg##*,}"
        elif [[ "$arg" == *"="* ]]; then
            version_script_file="${arg#*=}"
        fi
    fi
done
if [ -z "$version_script_file" ]; then
    args_arr=("$@")
    for ((i=0; i&lt;${#args_arr[@]}; i++)); do
        if [[ "${args_arr[i]}" == "--version-script" ]]; then
            version_script_file="${args_arr[i+1]}"
            break
        elif [[ "${args_arr[i]}" == "-Wl,--version-script" ]]; then
            version_script_file="${args_arr[i+1]}"
            break
        fi
    done
fi
echo "gcc-wrapper: found version script: $version_script_file" &gt;&gt; "${project.build.directory}/gcc_wrapper.log"
if [ -n "$version_script_file" ] &amp;&amp; [ -f "$version_script_file" ]; then
    echo "gcc-wrapper: modifying $version_script_file" &gt;&gt; "${project.build.directory}/gcc_wrapper.log"
    echo "gcc-wrapper: content before:" &gt;&gt; "${project.build.directory}/gcc_wrapper.log"
    cat "$version_script_file" &gt;&gt; "${project.build.directory}/gcc_wrapper.log"
    if ! grep -q "Java_org_pithos_" "$version_script_file"; then
        sed -i 's/global:/global:\n    Java_org_pithos_*;/g' "$version_script_file"
    fi
    echo "gcc-wrapper: content after:" &gt;&gt; "${project.build.directory}/gcc_wrapper.log"
    cat "$version_script_file" &gt;&gt; "${project.build.directory}/gcc_wrapper.log"
fi
exec gcc "$@"
EOF
                                            chmod +x "${project.build.directory}/gcc-wrapper.sh"
                                        </argument>
                                    </arguments>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>
                    <plugin>
                        <groupId>org.graalvm.buildtools</groupId>
                        <artifactId>native-maven-plugin</artifactId>
                        <version>${native.maven.plugin.version}</version>
                        <extensions>true</extensions>
                        <configuration>
                            <sharedLibrary>true</sharedLibrary>
                            <imageName>pithos</imageName>
                            <buildArgs>
                                <buildArg>--no-fallback</buildArg>
                                <buildArg>--add-modules=jdk.incubator.vector</buildArg>
                                <buildArg>-H:+UnlockExperimentalVMOptions</buildArg>
                                <buildArg>-H:+VectorAPISupport</buildArg>
                                <buildArg>--parallelism=3</buildArg>
                                <buildArg>-J-Xmx5g</buildArg>
                                <buildArg>-O3</buildArg>
                                <buildArg>-march=native</buildArg>
                                <buildArg>--native-compiler-path=${project.build.directory}/gcc-wrapper.sh</buildArg>
                                <buildArg>-H:NativeLinkerOption=-Wl,-u,Java_org_pithos_CudaDeviceManager_initialize</buildArg>
                                <buildArg>-H:NativeLinkerOption=-Wl,-u,Java_org_pithos_CudaDeviceManager_shutdown</buildArg>
                                <buildArg>-H:NativeLinkerOption=-Wl,-u,Java_org_pithos_CudaDeviceManager_isAvailable</buildArg>
                                <buildArg>-H:NativeLinkerOption=-Wl,-u,Java_org_pithos_CudaDeviceManager_getDeviceCount</buildArg>
                                <buildArg>-H:NativeLinkerOption=-Wl,-u,Java_org_pithos_CudaDeviceManager_getDeviceProperties</buildArg>
                                <buildArg>-H:NativeLinkerOption=-Wl,-u,Java_org_pithos_CudaMemoryManager_allocDevice</buildArg>
                                <buildArg>-H:NativeLinkerOption=-Wl,-u,Java_org_pithos_CudaMemoryManager_allocPinned</buildArg>
                                <buildArg>-H:NativeLinkerOption=-Wl,-u,Java_org_pithos_CudaMemoryManager_copyFromDevice</buildArg>
                                <buildArg>-H:NativeLinkerOption=-Wl,-u,Java_org_pithos_CudaMemoryManager_copyFromDeviceAsync</buildArg>
                                <buildArg>-H:NativeLinkerOption=-Wl,-u,Java_org_pithos_CudaMemoryManager_copyToDevice</buildArg>
                                <buildArg>-H:NativeLinkerOption=-Wl,-u,Java_org_pithos_CudaMemoryManager_copyToDeviceAsync</buildArg>
                                <buildArg>-H:NativeLinkerOption=-Wl,-u,Java_org_pithos_CudaMemoryManager_createStream</buildArg>
                                <buildArg>-H:NativeLinkerOption=-Wl,-u,Java_org_pithos_CudaMemoryManager_destroyStream</buildArg>
                                <buildArg>-H:NativeLinkerOption=-Wl,-u,Java_org_pithos_CudaMemoryManager_freeDevice</buildArg>
                                <buildArg>-H:NativeLinkerOption=-Wl,-u,Java_org_pithos_CudaMemoryManager_freePinned</buildArg>
                                <buildArg>-H:NativeLinkerOption=-Wl,-u,Java_org_pithos_CudaMemoryManager_getDirectBufferAddress</buildArg>
                                <buildArg>-H:NativeLinkerOption=-Wl,-u,Java_org_pithos_CudaMemoryManager_streamSynchronize</buildArg>
                                <buildArg>-H:NativeLinkerOption=-Wl,-u,Java_org_pithos_CudaNativeBindings_pithos_1cuda_1launch_1batch_1hamming</buildArg>
                                <buildArg>-H:NativeLinkerOption=-Wl,-u,Java_org_pithos_CudaNativeBindings_pithos_1cuda_1launch_1voting</buildArg>
                                <buildArg>-H:NativeLinkerOption=${project.build.directory}/pithos_kernels.o</buildArg>
                                <buildArg>-H:NativeLinkerOption=${project.build.directory}/pithos_cuda_memory.o</buildArg>
                                <buildArg>-H:NativeLinkerOption=${project.build.directory}/pithos_cuda.o</buildArg>
                                <buildArg>-H:NativeLinkerOption=${project.build.directory}/pithos_cuda_devicemanager.o</buildArg>
                                <buildArg>-H:NativeLinkerOption=${project.build.directory}/pithos_cuda_memorymanager.o</buildArg>
                                <buildArg>-H:NativeLinkerOption=${project.build.directory}/pithos_cuda_nativebindings.o</buildArg>
                                <buildArg>-H:NativeLinkerOption=${project.build.directory}/pithos_capi_cuda.o</buildArg>
                                <buildArg>-H:NativeLinkerOption=-lcuda</buildArg>
                                <buildArg>-H:NativeLinkerOption=-lcudart</buildArg>
                                <buildArg>-H:NativeLinkerOption=-L/usr/local/cuda/lib64</buildArg>
                                <!-- libcuda.so driver stub: path differs by architecture, so
                                     both are listed. The linker silently ignores paths that
                                     do not exist on the current build host. -->
                                <buildArg>-H:NativeLinkerOption=-L/usr/local/cuda/lib64/stubs</buildArg>
                                <buildArg>-H:NativeLinkerOption=-L/usr/local/cuda-12.5/targets/sbsa-linux/lib/stubs</buildArg>
                                <buildArg>-H:NativeLinkerOption=-L/usr/local/cuda-12.5/targets/x86_64-linux/lib/stubs</buildArg>
                            </buildArgs>
                        </configuration>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>
</project>